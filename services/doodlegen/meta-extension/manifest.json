{
   "action": {
      "default_icon": {
         "128": "images/icon128.png",
         "16": "images/icon16.png",
         "32": "images/icon32.png",
         "48": "images/icon48.png"
      },
      "default_title": "Meta Automator – Auto Meta Bulk AI Image & Video Generator"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "js": [ "flowContentScript.js" ],
      "matches": [ "https://www.meta.ai/create*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "Automate Meta AI video and image generation. Bulk create AI videos and images with custom settings.",
   "host_permissions": [ "https://www.meta.ai/*", "http://*/*", "https://*/*" ],
   "icons": {
      "128": "images/icon128.png",
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Meta Automator – Auto Meta Bulk AI Image & Video Generator",
   "permissions": [ "activeTab", "storage", "sidePanel", "identity", "tabs", "scripting", "downloads", "offscreen" ],
   "side_panel": {
      "default_path": "./src/index.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.2",
   "web_accessible_resources": [ {
      "matches": [ "https://www.meta.ai/*" ],
      "resources": [ "alwaysActive.js", "alwaysActiveIsolated.js", "logo.png" ]
   } ]
}
